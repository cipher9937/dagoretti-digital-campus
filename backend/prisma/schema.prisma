generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  firstName     String
  lastName      String
  phone         String?
  avatar        String?
  role          Role      @default(STUDENT)
  status        UserStatus @default(ACTIVE)
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLogin     DateTime?

  // Relations
  student       Student?
  teacher       Teacher?
  admin         Admin?
  sessions      Session[]
  notifications Notification[]
  activityLogs  ActivityLog[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  refreshToken String @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userAgent String?
  ipAddress String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model Student {
  id              String   @id @default(uuid())
  userId          String   @unique
  admissionNumber String   @unique
  dateOfBirth     DateTime?
  gender          Gender
  gradeLevel      GradeLevel
  streamId        String?
  parentName      String?
  parentPhone     String?
  parentEmail     String?
  address         String?
  enrollmentDate  DateTime @default(now())
  graduationDate  DateTime?

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stream          Stream?  @relation(fields: [streamId], references: [id])
  enrollments     Enrollment[]
  submissions     Submission[]
  attendances     Attendance[]
  libraryLoans    LibraryLoan[]

  @@index([admissionNumber])
  @@index([gradeLevel])
  @@index([streamId])
  @@map("students")
}

model Teacher {
  id              String   @id @default(uuid())
  userId          String   @unique
  employeeNumber  String   @unique
  departmentId    String?
  qualification   String?
  specialization  String?
  dateOfBirth     DateTime?
  gender          Gender
  joinDate        DateTime @default(now())
  isClassTeacher  Boolean  @default(false)
  classTeacherOf  String?  @unique

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  department      Department? @relation(fields: [departmentId], references: [id])
  classTeacherStream Stream? @relation("ClassTeacher", fields: [classTeacherOf], references: [id])
  subjectAssignments SubjectAssignment[]

  @@index([employeeNumber])
  @@index([departmentId])
  @@map("teachers")
}

model Admin {
  id          String   @id @default(uuid())
  userId      String   @unique
  adminLevel  AdminLevel @default(SCHOOL_ADMIN)
  department  String?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admins")
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  description String?
  headId      String?
  createdAt   DateTime @default(now())

  teachers    Teacher[]
  subjects    Subject[]

  @@map("departments")
}

model Class {
  id          String   @id @default(uuid())
  name        String
  gradeLevel  GradeLevel
  year        Int
  createdAt   DateTime @default(now())

  streams     Stream[]
  subjects    Subject[]
  timetables  Timetable[]

  @@unique([name, year])
  @@map("classes")
}

model Stream {
  id              String   @id @default(uuid())
  name            String
  classId         String
  classTeacherId  String?  @unique
  capacity        Int      @default(40)
  createdAt       DateTime @default(now())

  class           Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  classTeacher    Teacher? @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  students        Student[]

  @@unique([name, classId])
  @@map("streams")
}

model Subject {
  id            String   @id @default(uuid())
  name          String
  code          String   @unique
  description   String?
  departmentId  String?
  gradeLevel    GradeLevel[]
  isCore        Boolean  @default(false)
  creditHours   Int      @default(4)
  createdAt     DateTime @default(now())

  department    Department? @relation(fields: [departmentId], references: [id])
  assignments   Assignment[]
  resources     Resource[]
  subjectAssignments SubjectAssignment[]
  timetables    Timetable[]
  discussions   DiscussionBoard[]

  @@index([code])
  @@map("subjects")
}

model SubjectAssignment {
  id        String @id @default(uuid())
  teacherId String
  subjectId String
  streamId  String
  academicYear Int

  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId, streamId, academicYear])
  @@map("subject_assignments")
}

model Enrollment {
  id        String @id @default(uuid())
  studentId String
  subjectId String
  streamId  String
  academicYear Int
  term      Int

  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId, academicYear, term])
  @@map("enrollments")
}

model Assignment {
  id          String   @id @default(uuid())
  title       String
  description String?
  subjectId   String
  teacherId   String
  streamId    String?
  type        AssignmentType @default(HOMEWORK)
  dueDate     DateTime
  maxScore    Int      @default(100)
  attachments String[]
  instructions String?
  status      AssignmentStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([subjectId])
  @@index([dueDate])
  @@map("assignments")
}

model Submission {
  id            String   @id @default(uuid())
  assignmentId  String
  studentId     String
  content       String?
  attachments   String[]
  score         Int?
  feedback      String?
  status        SubmissionStatus @default(SUBMITTED)
  submittedAt   DateTime @default(now())
  gradedAt      DateTime?
  gradedBy      String?

  assignment    Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student       Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@map("submissions")
}

model Resource {
  id          String       @id @default(uuid())
  title       String
  description String?
  type        ResourceType
  subjectId   String?
  teacherId   String
  fileUrl     String?
  fileSize    Int?
  fileType    String?
  thumbnail   String?
  accessLevel AccessLevel  @default(ALL)
  downloadCount Int        @default(0)
  viewCount   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  subject     Subject?     @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([subjectId])
  @@map("resources")
}

model LibraryItem {
  id          String       @id @default(uuid())
  title       String
  author      String?
  isbn        String?
  type        LibraryType
  category    String
  subjectId   String?
  description String?
  coverImage  String?
  fileUrl     String?
  totalCopies Int          @default(1)
  availableCopies Int      @default(1)
  location    String?
  status      LibraryStatus @default(AVAILABLE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  loans       LibraryLoan[]

  @@index([type])
  @@index([category])
  @@map("library_items")
}

model LibraryLoan {
  id          String   @id @default(uuid())
  itemId      String
  studentId   String
  borrowedAt  DateTime @default(now())
  dueDate     DateTime
  returnedAt  DateTime?
  status      LoanStatus @default(ACTIVE)

  item        LibraryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("library_loans")
}

model Announcement {
  id          String   @id @default(uuid())
  title       String
  content     String
  type        AnnouncementType @default(SCHOOL_WIDE)
  targetId    String?
  priority    Priority @default(NORMAL)
  authorId    String
  publishedAt DateTime @default(now())
  expiresAt   DateTime?
  isPinned    Boolean  @default(false)

  @@index([type])
  @@index([publishedAt])
  @@map("announcements")
}

model News {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  category    String
  featuredImage String?
  authorId    String
  status      NewsStatus @default(DRAFT)
  publishedAt DateTime?
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([category])
  @@index([status])
  @@map("news")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  location    String?
  startDate   DateTime
  endDate     DateTime?
  category    String
  image       String?
  registrationUrl String?
  maxAttendees Int?
  status      EventStatus @default(UPCOMING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([startDate])
  @@index([status])
  @@map("events")
}

model Attendance {
  id        String   @id @default(uuid())
  studentId String
  date      DateTime
  status    AttendanceStatus
  subjectId String?
  markedBy  String
  notes     String?
  createdAt DateTime @default(now())

  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date, subjectId])
  @@index([studentId])
  @@index([date])
  @@map("attendance")
}

model OnlineClass {
  id          String   @id @default(uuid())
  title       String
  subjectId   String
  teacherId   String
  streamId    String?
  meetLink    String
  scheduledAt DateTime
  duration    Int      @default(60)
  recordingUrl String?
  notes       String?
  status      OnlineClassStatus @default(SCHEDULED)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([subjectId])
  @@index([scheduledAt])
  @@map("online_classes")
}

model Timetable {
  id        String   @id @default(uuid())
  classId   String
  subjectId String
  teacherId String
  dayOfWeek Int      // 0=Monday, 6=Sunday
  startTime String
  endTime   String
  room      String?
  term      Int
  academicYear Int

  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@map("timetables")
}

model DiscussionBoard {
  id          String   @id @default(uuid())
  subjectId   String
  title       String
  description String?
  createdBy   String
  isLocked    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  posts       DiscussionPost[]

  @@map("discussion_boards")
}

model DiscussionPost {
  id        String   @id @default(uuid())
  boardId   String
  authorId  String
  content   String
  parentId  String?
  attachments String[]
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board     DiscussionBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  parent    DiscussionPost? @relation("Replies", fields: [parentId], references: [id], onDelete: SetNull)
  replies   DiscussionPost[] @relation("Replies")

  @@map("discussion_posts")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@map("notifications")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entityType String
  entityId  String?
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  category  String   @default("GENERAL")
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model Gallery {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String
  imageUrl    String
  thumbnailUrl String?
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([category])
  @@map("gallery")
}

// Enums
enum Role {
  STUDENT
  TEACHER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum GradeLevel {
  GRADE_10
  FORM_3
  FORM_4
}

enum AdminLevel {
  SCHOOL_ADMIN
  SYSTEM_ADMIN
}

enum AssignmentType {
  HOMEWORK
  CLASSWORK
  PROJECT
  QUIZ
  EXAM
  LAB_REPORT
}

enum AssignmentStatus {
  ACTIVE
  DRAFT
  CLOSED
  ARCHIVED
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
  LATE
  PENDING
  RETURNED
}

enum ResourceType {
  NOTE
  VIDEO
  PRESENTATION
  WORKSHEET
  PAST_PAPER
  TEXTBOOK
  RESEARCH
  LINK
}

enum AccessLevel {
  ALL
  STUDENTS
  TEACHERS
  ADMIN
  SPECIFIC
}

enum LibraryType {
  TEXTBOOK
  REFERENCE
  FICTION
  NON_FICTION
  DIGITAL
  JOURNAL
  MAGAZINE
}

enum LibraryStatus {
  AVAILABLE
  BORROWED
  RESERVED
  LOST
  DAMAGED
}

enum LoanStatus {
  ACTIVE
  RETURNED
  OVERDUE
  LOST
}

enum AnnouncementType {
  SCHOOL_WIDE
  TEACHER_ONLY
  STUDENT_ONLY
  CLASS_SPECIFIC
  DEPARTMENT
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum NewsStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  SCHEDULED
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
  SICK
}

enum OnlineClassStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

enum NotificationType {
  ASSIGNMENT
  ANNOUNCEMENT
  GRADE
  ATTENDANCE
  EVENT
  SYSTEM
  MESSAGE
}
